{
  "private": true,
  "workspaces": [
    "apps/mobile",
    "apps/mobile-mock",
    "packages/shared-types"
  ],
  "scripts": {
    "prepare": "husky"
  },
  "overrides": {
    "react": "19.1.0"
  },
  "devDependencies": {
    "husky": "^9.1.7",
    "lint-staged": "^15.5.0"
  },
  "lint-staged": {
    "apps/mobile/**/*.{ts,tsx}": "bash -c 'npx tsc --noEmit -p apps/mobile/tsconfig.json'",
    "apps/mobile-mock/**/*.{ts,tsx}": "bash -c 'npx tsc --noEmit -p apps/mobile-mock/tsconfig.json'",
    "packages/shared-types/**/*.ts": "bash -c 'npx tsc --noEmit -p packages/shared-types/tsconfig.json'"
  }
}
